<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox OFF: required for Core Audio process taps and spawning the bundled Python pipeline (ADR-009). -->
	<key>com.apple.security.app-sandbox</key>
	<false/>
	<!-- Audio capture + outbound network (Drive sync) are wired in later slices; declared up front so the
	     signed identity is stable as TCC grants accumulate. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Keychain Services: store the Google credential in the data-protection keychain, owned by this
	     team-prefixed access group (stable across binary renames / re-signs) instead of the login
	     keychain's per-binary ACL — which rejected writes with errSecInvalidOwnerEdit (-25244) once the
	     app was renamed / re-signed. Team A6C6D257QN. -->
	<key>keychain-access-groups</key>
	<array>
		<string>A6C6D257QN.com.in-venture.in-meetings</string>
	</array>
</dict>
</plist>
