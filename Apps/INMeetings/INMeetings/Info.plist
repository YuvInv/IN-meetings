<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>INV Meetings</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSUIElement</key>
	<false/>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 IN Venture</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>INV Meetings records your microphone as a separate track so meetings can be transcribed with speaker attribution.</string>
	<key>NSAudioCaptureUsageDescription</key>
	<string>INV Meetings records the meeting's system audio (the remote participants) as a separate track for transcription.</string>
	<key>NSScreenCaptureUsageDescription</key>
	<string>INV Meetings records the call window (participants and shared screen) as a video of the meeting for review.</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.in-venture.in-meetings.google-oauth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.1062382667236-p1ignhh12l0e9al7he5esph13s8lm1qf</string>
			</array>
		</dict>
	</array>
	<!-- Sparkle 2 auto-update. Feed is served from GitHub Pages (gh-pages branch); each appcast
	     item is EdDSA-signed with the key whose public half is below. Updates work for unsigned
	     internal builds too — the $99 Apple account only gates a Gatekeeper-clean first install. -->
	<key>SUFeedURL</key>
	<string>https://yuvinv.github.io/IN-meetings/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>HHZxCHI5p5v+P+CKjX8sbC+LxAbv2vP3mhWCXwifHAI=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
	<!-- Google Picker browser API key, baked in at build time from the GOOGLE_PICKER_API_KEY build
	     setting (fed by .secrets/picker_api_key.txt locally / the CI secret). Empty on a plain build. -->
	<key>GooglePickerAPIKey</key>
	<string>$(GOOGLE_PICKER_API_KEY)</string>
</dict>
</plist>
