<?xml version="1.0" encoding="utf-8"?>
<!--
  appcast.xml — Sparkle 2 auto-update feed template
  ===================================================
  STATUS: NOT YET SERVED. This is a committed template showing the correct
  structure. The live feed is generated by `generate_appcast` (Sparkle CLI)
  and published to the `gh-pages` branch by the release workflow ONLY after
  the account-gated signing/Sparkle steps are activated.

  When active, it will be served at:
    https://<org>.github.io/IN-meetings/appcast.xml

  Set SUFeedURL in Apps/INMeetings/project.yml to that URL once gh-pages is
  live. See docs/distribution-setup.md → "Release hosting + auto-update".

  Key fields:
    sparkle:version             — BUILD number (CURRENT_PROJECT_VERSION in project.yml)
                                  Sparkle compares this for "is there an update?"
    sparkle:shortVersionString  — marketing version (MARKETING_VERSION) shown to users
    sparkle:edSignature         — EdDSA signature produced by generate_appcast; never
                                  hand-edit this value
    url                         — direct download link for the .zip from GitHub Releases
                                  (Sparkle downloads a .zip, NOT a .dmg)
    length                      — byte count of the .zip (fill in at release time or let
                                  generate_appcast fill it automatically)
-->
<rss version="2.0"
     xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle"
     xmlns:dc="http://purl.org/dc/elements/1.1/">
  <channel>
    <title>INV Meetings</title>
    <link>https://yuvinv.github.io/IN-meetings/appcast.xml</link>
    <description>INV Meetings release feed</description>
    <language>en</language>

    <!-- ── Example release item — generated_appcast fills this automatically ── -->
    <item>
      <title>Version 0.1.0</title>
      <pubDate>Tue, 24 Jun 2026 00:00:00 +0000</pubDate>
      <sparkle:version>1</sparkle:version>             <!-- BUILD number -->
      <sparkle:shortVersionString>0.1.0</sparkle:shortVersionString>
      <sparkle:releaseNotesLink>
        https://github.com/YuvInv/IN-meetings/releases/tag/v0.1.0
      </sparkle:releaseNotesLink>
      <enclosure
        url="https://github.com/YuvInv/IN-meetings/releases/download/v0.1.0/INMeetings.zip"
        type="application/octet-stream"
        length="0"
        sparkle:edSignature="PLACEHOLDER_REPLACE_WITH_generate_appcast_OUTPUT" />
    </item>

  </channel>
</rss>
